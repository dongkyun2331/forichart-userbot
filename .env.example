# Core
RPC_URL=https://bsc-dataseed.binance.org
CHAIN_ID=56
PAPER_MODE=1
POLL_SECONDS=1
SIGNAL_URL=https://api.fori.kr/api/bot/signal
SIGNAL_WS_URL=wss://api.fori.kr/api/bot/signal/ws
BOT_CONFIG_URL=https://api.fori.kr/api/bot/config
# direct: 기존 라우터 직접 스왑
# guard: ExecutionGuardV3 executeV3만 사용 (intent+signature 필요)
# auto: intent+signature 있으면 guard, 없으면 direct
EXECUTION_MODE=direct
# deployed guard (BSC): 0x1AbA5EE8745481480D0EA27FE667f51e20526394
EXECUTION_GUARD_ADDRESS=0x1AbA5EE8745481480D0EA27FE667f51e20526394
# Local test example:
# SIGNAL_URL=http://host.docker.internal:8080/signal
SIGNAL_TOKEN=
MIN_CONFIDENCE=0.65

# Wallet (live mode only)
PRIVATE_KEY=
WALLET_ADDRESS=

# Swap router
# v2 router
ROUTER_ADDRESS=0x10ED43C718714eb63d5aA57B78B54704E256024E
# v3 router/quoter
V3_ROUTER_ADDRESS=0x1b81D678ffb9C0263b24A97847620C99d213eB14
V3_QUOTER_ADDRESS=0xB048Bbc1Ee6b733FFfCFb9e9CeF7375518e25997
# comma-separated fee tiers (auto best route among v2/v3 quotes)
V3_FEE_TIERS=500,2500,10000

# Trade pair (fallback only; backend /api/bot/config 우선)
BASE_TOKEN_ADDRESS=0x55d398326f99059fF775485246999027B3197955
QUOTE_TOKEN_ADDRESS=0xe9e7cea3dedca5984780bafc599bd69add087d56
BASE_TOKEN_SYMBOL=USDT
QUOTE_TOKEN_SYMBOL=BUSD
BASE_TOKEN_DECIMALS=18
QUOTE_TOKEN_DECIMALS=18
ALLOWED_TOKENS=0x55d398326f99059fF775485246999027B3197955,0xe9e7cea3dedca5984780bafc599bd69add087d56

# Amount
BUY_AMOUNT_BASE=20
SELL_AMOUNT_QUOTE=20

# Risk guards
MAX_SLIPPAGE_BPS=80
MAX_GAS_GWEI=6
COOLDOWN_SECONDS=120
DAILY_NOTIONAL_LIMIT_USD=300

# Files
STATE_FILE=./data/state.json
TRADE_LOG_FILE=./data/trades.ndjson
